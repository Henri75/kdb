# Atlas configuration — copy to .env and adjust.
# Host paths mounted read-only into the stack (compose maps them to /data/*).
CODE_ROOT_HOST=/Users/nasta/__CODING NEW
CLAUDE_PROJECTS_HOST=/Users/nasta/.claude/projects

# Extra project trees to index (up to four). Uncomment and point at any folder
# holding more projects; each is mounted read-only. Restart with
# `docker compose up -d` after changing these — no reindex flag needed.
#CODE_ROOT_HOST_2=/Users/nasta/Work
#CODE_ROOT_HOST_3=/Volumes/CloudBox/Projects
#CODE_ROOT_HOST_4=
#CODE_ROOT_HOST_5=

# In-container paths (leave as-is when running under compose).
CODE_ROOT=/data/code
CLAUDE_PROJECTS_DIR=/data/claude/projects

# Infrastructure.
DATABASE_URL=postgres://kdbscope:kdbscope@postgres:5432/kdbscope
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

# Indexing.
SCAN_INTERVAL_MIN=5
# Parallel scan jobs. A local Ollama serialises embed requests, so more workers
# only deepen its queue. Raise for a remote/batched embedding endpoint.
WORKER_CONCURRENCY=2

# Embeddings: auto | ollama | bundled | openai | g2p
# 'auto' prefers Ollama (much faster, 768-dim) and pulls the model on first
# boot; it falls back to the bundled CPU model with a warning if Ollama is down.
EMBEDDINGS_PROVIDER=auto
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# Ask-mode LLM: openai | g2p   (g2p = OpenAI-compatible proxy, no key needed)
LLM_PROVIDER=g2p
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=http://host.docker.internal:8181/v1
LLM_API_KEY=

# Service ports (host side, 127.0.0.1 only).
API_PORT=8710
MCP_PORT=8711
UI_PORT=8712
QDRANT_PORT=6363
QDRANT_GRPC_PORT=6364
REDIS_PORT=6390
POSTGRES_PORT=5460

# Internal URL the mcp/cli/ui use to reach the API.
KDBSCOPE_API_URL=http://api:8710
