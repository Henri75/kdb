{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@atlas/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": [
    "packages/core/src/**/*.ts",
    "packages/indexer/src/**/*.ts",
    "packages/api/src/**/*.ts",
    "packages/mcp/src/**/*.ts",
    "packages/cli/src/**/*.ts",
    "test/**/*.ts"
  ]
}
